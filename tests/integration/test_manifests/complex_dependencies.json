{
  "project": "complex-bank-analysis",
  "mode": "hierarchical",
  "abort_on_stage_failure": false,
  "dispatches": [
    {
      "agent": "data-source-validator",
      "priority": "P0",
      "task": "Validate all data sources are accessible",
      "verify_cmd": "curl -f http://localhost:8080/health",
      "stage": 1,
      "locks": ["source_validation.lock"]
    },
    {
      "agent": "schema-validator",
      "priority": "P0",
      "task": "Validate data schemas and formats",
      "verify_cmd": "python -m bankstatementparser.validate_schemas",
      "stage": 1,
      "locks": ["schema.lock"]
    },
    {
      "agent": "historical-data-loader",
      "priority": "P1",
      "task": "Load historical transaction data",
      "verify_cmd": "test -f /tmp/historical_loaded.flag",
      "stage": 2,
      "depends_on": ["data-source-validator", "schema-validator"],
      "locks": ["historical_data.db", "temp_storage.db"]
    },
    {
      "agent": "current-data-processor",
      "priority": "P1",
      "task": "Process current period transactions",
      "verify_cmd": "test -f /tmp/current_processed.flag",
      "stage": 2,
      "depends_on": ["schema-validator"],
      "locks": ["current_data.db", "temp_storage.db"]
    },
    {
      "agent": "fraud-detector",
      "priority": "P0",
      "task": "Run fraud detection algorithms",
      "verify_cmd": "test -f /tmp/fraud_analysis.flag",
      "stage": 3,
      "depends_on": ["historical-data-loader", "current-data-processor"],
      "locks": ["fraud_detection.db", "ml_models.lock"]
    },
    {
      "agent": "trend-analyzer",
      "priority": "P1",
      "task": "Analyze spending and income trends",
      "verify_cmd": "test -f /tmp/trends_analyzed.flag",
      "stage": 3,
      "depends_on": ["historical-data-loader", "current-data-processor"],
      "locks": ["analytics.db", "ml_models.lock"]
    },
    {
      "agent": "compliance-checker",
      "priority": "P0",
      "task": "Check regulatory compliance",
      "verify_cmd": "test -f /tmp/compliance_verified.flag",
      "stage": 3,
      "depends_on": ["current-data-processor"],
      "locks": ["compliance.db", "regulatory_rules.lock"]
    },
    {
      "agent": "risk-assessor",
      "priority": "P1",
      "task": "Assess portfolio and transaction risks",
      "verify_cmd": "test -f /tmp/risk_assessed.flag",
      "stage": 4,
      "depends_on": ["fraud-detector", "trend-analyzer", "compliance-checker"],
      "locks": ["risk_models.db", "calculations.lock"]
    },
    {
      "agent": "dashboard-generator",
      "priority": "P2",
      "task": "Generate executive dashboard",
      "verify_cmd": "test -f /tmp/dashboard_ready.flag",
      "stage": 5,
      "depends_on": ["risk-assessor", "trend-analyzer"],
      "locks": ["dashboard.db", "charts.lock"]
    },
    {
      "agent": "alert-processor",
      "priority": "P0",
      "task": "Process and send alerts for anomalies",
      "verify_cmd": "test -f /tmp/alerts_sent.flag",
      "stage": 5,
      "depends_on": ["fraud-detector", "risk-assessor", "compliance-checker"],
      "locks": ["notifications.db", "email.lock"]
    },
    {
      "agent": "backup-manager",
      "priority": "P3",
      "task": "Backup processed data and results",
      "verify_cmd": "test -f /tmp/backup_complete.flag",
      "stage": 6,
      "depends_on": ["dashboard-generator", "alert-processor"],
      "locks": ["backup_storage.lock", "archive.db"]
    }
  ]
}